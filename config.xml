<?xml version='1.0' encoding='utf-8'?>
<widget id="com.smartworker.app" version="1.1.0"
        xmlns="http://www.w3.org/ns/widgets"
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:cdv="http://cordova.apache.org/ns/1.0">

    <name>SmartWorker</name>
    <description>Professional Attendance and Employee Management</description>
    <author email="admin@smartworker.com">SmartWorker Team</author>

    <content src="index.html" />

    <platform name="android">
        <allow-intent href="market:*" />

        <!-- Launcher icon: the SmartWorker logo at every screen density -->
        <icon density="ldpi" src="res/android/icon/ldpi.png" />
        <icon density="mdpi" src="res/android/icon/mdpi.png" />
        <icon density="hdpi" src="res/android/icon/hdpi.png" />
        <icon density="xhdpi" src="res/android/icon/xhdpi.png" />
        <icon density="xxhdpi" src="res/android/icon/xxhdpi.png" />
        <icon density="xxxhdpi" src="res/android/icon/xxxhdpi.png" />

        <!-- Splash (Android 11 and below): branded navy with centered logo -->
        <splash density="port-mdpi" src="res/android/splash/port-mdpi.png" />
        <splash density="port-hdpi" src="res/android/splash/port-hdpi.png" />
        <splash density="port-xhdpi" src="res/android/splash/port-xhdpi.png" />
        <splash density="port-xxhdpi" src="res/android/splash/port-xxhdpi.png" />
        <splash density="port-xxxhdpi" src="res/android/splash/port-xxxhdpi.png" />

        <!-- Splash (Android 12+ system SplashScreen API): navy background with
             the logo as the centered animated icon -->
        <preference name="AndroidWindowSplashScreenBackground" value="#001F3F" />
        <preference name="AndroidWindowSplashScreenAnimatedIcon" value="res/android/splash-icon.png" />

        <preference name="android-minSdkVersion" value="24" />
        <preference name="android-targetSdkVersion" value="34" />
        <preference name="AndroidXEnabled" value="true" />
        <!-- Production WebView performance -->
        <preference name="AndroidInsecureFileModeEnabled" value="false" />
        <preference name="ResolveServiceWorkerRequests" value="true" />
        <!-- Camera permission for the in-app QR scanner (getUserMedia in WebView) -->
        <config-file target="AndroidManifest.xml" parent="/manifest">
            <uses-permission android:name="android.permission.CAMERA" />
            <uses-feature android:name="android.hardware.camera" android:required="false" />
        </config-file>
        <!-- GPU rendering + large heap for html2canvas/jsPDF capture buffers -->
        <edit-config file="AndroidManifest.xml" target="/manifest/application" mode="merge">
            <application android:hardwareAccelerated="true" android:largeHeap="true" />
        </edit-config>
    </platform>

    <preference name="DisallowOverscroll" value="true" />
    <preference name="android-hardwareAccelerated" value="true" />
    <preference name="Orientation" value="portrait" />
    <preference name="StatusBarOverlaysWebView" value="false" />
    <preference name="StatusBarBackgroundColor" value="#001F3F" />
    <preference name="StatusBarStyle" value="lightcontent" />
    <preference name="BackgroundColor" value="0xff001F3F" />
    <!-- Faster startup: shorter splash, app content shows as soon as ready -->
    <preference name="SplashScreenDelay" value="800" />
    <preference name="FadeSplashScreenDuration" value="200" />
    <preference name="AutoHideSplashScreen" value="true" />
    <preference name="ShowSplashScreenSpinner" value="false" />
    <preference name="LoadUrlTimeoutValue" value="60000" />
    <preference name="KeepRunning" value="true" />

    <!-- IMPORTANT: Update these URLs before building for production.
         Replace the placeholder with your actual deployed server domain.
         Example: https://smartworker-yourname.replit.app
         Keep localhost for development builds. -->
    <allow-navigation href="https://smartworker-yourname.replit.app/*" />
    <allow-navigation href="http://localhost/*" />
    <allow-navigation href="http://127.0.0.1/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="mailto:*" />

    <!-- cordova-plugin-whitelist removed: deprecated and built into cordova-android 10+ -->
    <plugin name="cordova-plugin-network-information" spec="^3.0.0" />
    <plugin name="cordova-plugin-splashscreen" spec="^6.0.0" />
    <plugin name="cordova-plugin-statusbar" spec="^3.0.0" />
    <!-- Requests the Android runtime CAMERA permission so the in-app QR scanner
         (getUserMedia in the WebView) can open the camera. cordova-android
         already grants the WebView's permission request, but the OS still
         requires the app to hold the runtime permission. -->
    <plugin name="cordova-plugin-android-permissions" spec="^1.1.5" />

    <!-- Restrict network access to only the backend API domain for security.
         Update the origin below to match your deployed server URL. -->
    <access origin="https://smartworker-yourname.replit.app" />
    <!-- Supabase Storage serves worker photos and the company logo -->
    <access origin="https://*.supabase.co" />
    <access origin="http://localhost" />
    <access origin="http://127.0.0.1" />
</widget>
